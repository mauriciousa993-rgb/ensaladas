NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WOMPI_REDIRECT_URL=http://localhost:3000/payment/response

# Demo mode (no MongoDB, datos mock)
# NEXT_PUBLIC_DEMO_MODE=true
# DEMO_MODE=true

# Server-side (Next API routes)
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/ensaladas

# Opcional: si quieres que el frontend apunte a un backend externo (Render/otro)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3002

# Opcional: Cloudinary (para subir imágenes desde el admin)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=ensaladas

# Opcional: WhatsApp/Twilio (notificación de nuevos pedidos)
# WHATSAPP_BUSINESS_NUMBER=573001234567
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
